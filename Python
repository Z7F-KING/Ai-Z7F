import asyncio
from holehe import core

async def search_email_info(email):
    # إعداد الوحدات النمطية للفحص
    modules = core.import_submodules("holehe.modules")
    
    print(f"\n[*] جاري الفحص عن: {email}")
    print("-" * 30)

    # حلقة للفحص عبر المواقع المختلفة
    tasks = []
    for module in modules:
        try:
            tasks.append(core.get_functions(module, email, {}))
        except:
            continue

    # تنفيذ الفحص
    results = await asyncio.gather(*tasks)

    # عرض النتائج التي وجدنا فيها حسابات
    found_any = False
    for result in results:
        if result and result[0]['exists']:
            print(f"[+] موجود في: {result[0]['name']}")
            found_any = True
    
    if not found_any:
        print("[-] لم يتم العثور على حسابات مرتبطة بهذا البريد في المواقع الشهيرة.")

if __name__ == "__main__":
    target_email = input("أدخل البريد الإلكتروني المراد فحصـه: ")
    asyncio.run(search_email_info(target_email))
