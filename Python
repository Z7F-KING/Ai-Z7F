import asyncio
from holehe import core

async def search_email_info(email):
    modules = core.import_submodules("holehe.modules")

    print(f"\n[*] جاري الفحص عن: {email}")
    print("-" * 40)

    semaphore = asyncio.Semaphore(10)  # تحديد عدد العمليات المتوازية

    async def run_module(module):
        async with semaphore:
            try:
                return await core.get_functions(module, email, {})
            except Exception:
                return None

    tasks = [run_module(module) for module in modules]

    results = await asyncio.gather(*tasks)

    found_any = False

    for result in results:
        try:
            if result and isinstance(result, list):
                for r in result:
                    if r.get("exists"):
                        print(f"[+] موجود في: {r.get('name')}")
                        found_any = True
        except Exception:
            continue

    if not found_any:
        print("[-] لم يتم العثور على حسابات مرتبطة بهذا البريد.")

if __name__ == "__main__":
    email = input("أدخل البريد الإلكتروني: ").strip()
    asyncio.run(search_email_info(email))
