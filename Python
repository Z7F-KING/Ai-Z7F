import webbrowser
import requests

def osint_email_hunt(email):
    print(f"[*] بدء عملية التقصي الرقمي عن: {email}")
    print("-" * 40)

    # 1. فحص تسريبات قواعد البيانات (Data Breaches)
    # نستخدم هنا API يعطي معلومات عن المواقع التي سُرب منها البريد
    print("[+] فحص سجلات التسريبات...")
    try:
        # محرك بحث عن التسريبات (مجاني ومفتوح)
        api_url = f"https://api.proxynova.com/comb?query={email}"
        response = requests.get(api_url, timeout=10)
        if response.status_code == 200:
            results = response.json().get("results", [])
            if results:
                print(f"[!] تم العثور على البريد في {len(results)} سجل مسرب!")
                for r in results[:3]: # عرض أول 3 نتائج كمثال
                    print(f"    - نتيجة محتملة: {r}")
            else:
                print("[-] لم يتم العثور على البريد في قواعد البيانات العامة.")
    except:
        print("[!] فشل الاتصال بقاعدة بيانات التسريبات.")

    # 2. توليد روابط "الاستخبارات" (Google Dorks)
    # هذه الروابط تفتح لك متصفح سفاري/كروم وتبحث عن البريد في أماكن حساسة
    print("\n[+] توليد روابط التقصي في جوجل وسفاري...")
    
    dorks = {
        "البحث عن ملفات (PDF/Doc)": f'https://www.google.com/search?q=filetype:pdf OR filetype:doc "{email}"',
        "البحث في منصات التواصل": f'https://www.google.com/search?q=site:facebook.com OR site:twitter.com OR site:instagram.com "{email}"',
        "البحث في الأكواد (GitHub/StackOverflow)": f'https://www.google.com/search?q=site:github.com OR site:stackoverflow.com "{email}"',
        "البحث عن منشروات عامة": f'https://www.google.com/search?q="{email}"'
    }

    for label, url in dorks.items():
        print(f"[*] جاري فتح: {label}")
        webbrowser.open(url)

    print("\n" + "="*40)
    print("تم فتح روابط البحث المتقدم في متصفحك.")
    print("افحص النتائج في جوجل بدقة، غالباً ستجد روابط قديمة أو ملفات مخفية.")
    print("="*40)

if __name__ == "__main__":
    email_to_check = input("أدخل البريد المراد صيده: ")
    osint_email_hunt(email_to_check)
